# Terraform state (LOCAL state for this POC — may contain secrets, never commit)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log

# Real variable values (may hold environment-specific config)
terraform.tfvars
*.auto.tfvars

# Lambda build artifact (regenerated by archive_file)
modules/email-router/build/

# OS cruft
.DS_Store
