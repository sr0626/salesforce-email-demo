{
  "Version" : "2012-10-17",
  "Id" : "poc-shared-cmk-policy",
  "Statement" : [ {
    "Sid" : "EnableAccountAdminAndIamDelegation",
    "Effect" : "Allow",
    "Principal" : {
      "AWS" : "arn:aws:iam::044336301301:root"
    },
    "Action" : "kms:*",
    "Resource" : "*"
  }, {
    "Sid" : "AllowCloudWatchLogsEncryption",
    "Effect" : "Allow",
    "Principal" : {
      "Service" : "logs.us-west-2.amazonaws.com"
    },
    "Action" : [ "kms:Encrypt", "kms:Decrypt", "kms:ReEncrypt*", "kms:GenerateDataKey*", "kms:DescribeKey" ],
    "Resource" : "*",
    "Condition" : {
      "ArnLike" : {
        "kms:EncryptionContext:aws:logs:arn" : "arn:aws:logs:us-west-2:044336301301:log-group:*"
      }
    }
  }, {
    "Sid" : "AllowUseThroughAwsServicesInThisAccount",
    "Effect" : "Allow",
    "Principal" : {
      "AWS" : "*"
    },
    "Action" : [ "kms:Encrypt", "kms:Decrypt", "kms:ReEncrypt*", "kms:GenerateDataKey*", "kms:DescribeKey" ],
    "Resource" : "*",
    "Condition" : {
      "StringEquals" : {
        "kms:CallerAccount" : "044336301301"
      },
      "StringLike" : {
        "kms:ViaService" : "*.us-west-2.amazonaws.com"
      }
    }
  }, {
    "Sid" : "AllowGrantsForAwsResourcesInThisAccount",
    "Effect" : "Allow",
    "Principal" : {
      "AWS" : "*"
    },
    "Action" : [ "kms:CreateGrant", "kms:ListGrants", "kms:RevokeGrant" ],
    "Resource" : "*",
    "Condition" : {
      "StringEquals" : {
        "kms:CallerAccount" : "044336301301"
      },
      "Bool" : {
        "kms:GrantIsForAWSResource" : "true"
      }
    }
  }, {
    "Sid" : "AllowSESToEncryptInboundEmail",
    "Effect" : "Allow",
    "Principal" : {
      "Service" : "ses.amazonaws.com"
    },
    "Action" : [ "kms:GenerateDataKey", "kms:Encrypt" ],
    "Resource" : "*",
    "Condition" : {
      "StringEquals" : {
        "aws:SourceAccount" : "044336301301"
      },
      "StringLike" : {
        "aws:SourceArn" : "arn:aws:ses:us-west-2:044336301301:receipt-rule-set/*"
      }
    }
  } ]
}
